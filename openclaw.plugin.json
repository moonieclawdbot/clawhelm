{
  "id": "clawhelm",
  "name": "ClawHelm",
  "description": "Local task classification router for OpenClaw-configured models",
  "configSchema": {
    "type": "object",
    "properties": {
      "routing": {
        "type": "object",
        "description": "Routing/classification overrides. All model IDs must exist in OpenClaw model config.",
        "properties": {
          "classifier": {
            "type": "object",
            "properties": {
              "llmModel": {
                "type": "string",
                "description": "Model used for classifier fallback when rule scoring is ambiguous"
              },
              "llmMaxTokens": { "type": "number" },
              "llmTemperature": { "type": "number" },
              "promptTruncationChars": { "type": "number" },
              "cacheTtlMs": { "type": "number" }
            }
          },
          "modelPool": {
            "type": "array",
            "description": "Optional allowlist of model IDs. When set, ClawHelm only routes to models present in this list and in OpenClaw provider model config.",
            "items": { "type": "string" }
          },
          "tiers": {
            "type": "object",
            "description": "Tier-to-model mapping: tasks are classified into tiers, and each tier selects from its configured primary/fallback chain.",
            "properties": {
              "SIMPLE": {
                "type": "object",
                "properties": {
                  "primary": { "type": "string" },
                  "fallback": { "type": "array", "items": { "type": "string" } }
                }
              },
              "MEDIUM": {
                "type": "object",
                "properties": {
                  "primary": { "type": "string" },
                  "fallback": { "type": "array", "items": { "type": "string" } }
                }
              },
              "COMPLEX": {
                "type": "object",
                "properties": {
                  "primary": { "type": "string" },
                  "fallback": { "type": "array", "items": { "type": "string" } }
                }
              },
              "REASONING": {
                "type": "object",
                "properties": {
                  "primary": { "type": "string" },
                  "fallback": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    }
  }
}
