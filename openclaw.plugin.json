{
  "id": "clawhelm",
  "name": "ClawHelm",
  "description": "Local task-classification router plugin that selects from OpenClaw-available model IDs (built-in catalog and/or models.providers.<providerId>.models)",
  "configSchema": {
    "type": "object",
    "properties": {
      "routing": {
        "type": "object",
        "description": "Routing/classification overrides for plugins.clawhelm.routing in openclaw.json. All model IDs must be valid OpenClaw model refs (built-in catalog or models.providers.<providerId>.models).",
        "properties": {
          "classifier": {
            "type": "object",
            "properties": {
              "llmModel": {
                "type": "string",
                "description": "Model used for classifier fallback when rule scoring is ambiguous"
              },
              "llmMaxTokens": { "type": "number" },
              "llmTemperature": { "type": "number" },
              "promptTruncationChars": { "type": "number" },
              "cacheTtlMs": { "type": "number" }
            }
          },
          "allowedModels": {
            "type": "array",
            "description": "Optional strict allowlist of model IDs ClawHelm may select. Entries must exist under models.providers.*.models.",
            "items": { "type": "string" }
          },
          "tiers": {
            "type": "object",
            "description": "Tier-to-model mapping for default routing. Each tier selects from a primary/fallback model chain.",
            "properties": {
              "SIMPLE": {
                "type": "object",
                "properties": {
                  "primary": { "type": "string" },
                  "fallback": { "type": "array", "items": { "type": "string" } }
                }
              },
              "MEDIUM": {
                "type": "object",
                "properties": {
                  "primary": { "type": "string" },
                  "fallback": { "type": "array", "items": { "type": "string" } }
                }
              },
              "COMPLEX": {
                "type": "object",
                "properties": {
                  "primary": { "type": "string" },
                  "fallback": { "type": "array", "items": { "type": "string" } }
                }
              },
              "REASONING": {
                "type": "object",
                "properties": {
                  "primary": { "type": "string" },
                  "fallback": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          },
          "agenticTiers": {
            "type": "object",
            "description": "Optional tier-to-model mapping used for detected or forced agentic workflows.",
            "properties": {
              "SIMPLE": {
                "type": "object",
                "properties": {
                  "primary": { "type": "string" },
                  "fallback": { "type": "array", "items": { "type": "string" } }
                }
              },
              "MEDIUM": {
                "type": "object",
                "properties": {
                  "primary": { "type": "string" },
                  "fallback": { "type": "array", "items": { "type": "string" } }
                }
              },
              "COMPLEX": {
                "type": "object",
                "properties": {
                  "primary": { "type": "string" },
                  "fallback": { "type": "array", "items": { "type": "string" } }
                }
              },
              "REASONING": {
                "type": "object",
                "properties": {
                  "primary": { "type": "string" },
                  "fallback": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          },
          "overrides": {
            "type": "object",
            "properties": {
              "maxTokensForceComplex": { "type": "number" },
              "structuredOutputMinTier": {
                "type": "string",
                "enum": ["SIMPLE", "MEDIUM", "COMPLEX", "REASONING"]
              },
              "ambiguousDefaultTier": {
                "type": "string",
                "enum": ["SIMPLE", "MEDIUM", "COMPLEX", "REASONING"]
              },
              "agenticMode": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
